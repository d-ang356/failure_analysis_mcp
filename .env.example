# MCP Server Configuration for WebdriverIO Integration
# Copy this file to .env and customize the values

# WebdriverIO MCP Client Configuration
# URL where the WebdriverIO MCP client will connect from
MCP_CLIENT_URL=http://localhost:3000
MCP_CLIENT_PORT=3000

# Ollama LLM Configuration
# Host where Ollama is running
MCP_OLLAMA_HOST=http://localhost:11434
# Model to use for analysis (must be pulled in Ollama).
# For vision/screenshot analysis, use a vision-capable model like gemma4:e4b or qwen3-vl:8b.
MCP_OLLAMA_MODEL=gemma4:e4b
# Temperature for LLM responses (0.0 - 1.0, lower is more deterministic)
MCP_OLLAMA_TEMPERATURE=0.1
# Context window size in tokens. Increase if sending large DOM snapshots.
MCP_OLLAMA_NUM_CTX=131072
# Request timeout in seconds
MCP_OLLAMA_TIMEOUT=300

# Analysis Configuration
# How many levels deep to traverse imports (1-5)
MCP_MAX_IMPORT_DEPTH=3
# Maximum file size to analyze in KB
MCP_MAX_FILE_SIZE_KB=500
# Maximum DOM snapshot size to send to the LLM in KB (after cleaning)
MCP_MAX_DOM_SIZE_KB=100
# Session time-to-live in minutes
MCP_SESSION_TTL_MINUTES=60
# Maximum number of failures to keep in session history
MCP_MAX_SESSION_HISTORY=10

# Logging
# Log level: DEBUG, INFO, WARNING, ERROR
MCP_LOG_LEVEL=INFO
